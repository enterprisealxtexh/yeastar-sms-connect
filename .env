# Local API Configuration (SQLite Backend)
# Frontend will connect to local API server running on port 2004
VITE_API_URL="http://localhost:2004"
VITE_API_ENABLED="true"

# Single SQLite Database (no separate databases)
# Location: public/local-agent/sms.db (absolute path resolved at runtime)
SMS_DB_PATH="./public/local-agent/sms.db"
